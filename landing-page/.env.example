# ─────────────────────────────────────────────────────────────
# Browser voice widget (client-side, public)
# ─────────────────────────────────────────────────────────────
# Get your agent ID from the ElevenLabs dashboard:
# https://elevenlabs.io/app/conversational-ai
#
# Requirements for the embed widget:
# - Agent must be public (authentication disabled in Advanced settings)
# - Add your domain to the allowlist in the Security tab
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your_agent_id_here

# ─────────────────────────────────────────────────────────────
# Outbound telephony / test call (server-side, secret)
# Powers the "Call me" button on the landing page via the
# ElevenLabs Twilio outbound-call API.
# https://elevenlabs.io/docs/eleven-agents/phone-numbers/twilio-integration/native-integration
# ─────────────────────────────────────────────────────────────
# Your ElevenLabs API key (keep this secret — server only):
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_api_key_here

# The agent that should handle outbound calls. This can be the same
# agent ID as the widget above, or a dedicated outbound agent.
ELEVENLABS_AGENT_ID=your_agent_id_here

# The ID of the Twilio phone number linked to your agent. Find it in
# the ElevenLabs dashboard under Phone Numbers after importing a
# Twilio number or verified caller ID.
ELEVENLABS_AGENT_PHONE_NUMBER_ID=your_phone_number_id_here
