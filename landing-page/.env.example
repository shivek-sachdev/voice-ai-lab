# --- ElevenLabs voice agent configuration ---
# Get these from the ElevenLabs dashboard: https://elevenlabs.io/app/conversational-ai

# Your agent's ID (safe to expose to the browser).
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your_agent_id_here

# Your ElevenLabs API key (SECRET — server-side only, never exposed to the browser).
# Recommended: keep your agent PRIVATE (authentication enabled) and set this key.
# The server exchanges it for a short-lived signed URL so the key stays secret.
#
# If you leave this blank, the app falls back to connecting as a PUBLIC agent,
# which only works when authentication is disabled for the agent.
ELEVENLABS_API_KEY=your_api_key_here
